# ── Telegram ─────────────────────────────────────────────────
BOT_TOKEN=8858693463:AAEf2t1kWgBD6gv7-Nlm7si1HPABdRA9C-0
ADMIN_IDS=5580566610         # @userinfobot dan oling
COMMUNITY_CHAT_ID=-1003971904106                      # Guruh ID, bo'sh = dev rejim
DISABLE_GROUP_CHECK=true                # production: false

# ── Mini App / API ────────────────────────────────────────────
MINI_APP_URL=http://localhost:5173
API_URL=http://localhost:8001
INTERNAL_API_URL=http://localhost:8001
RADIO_PUBLIC_URL=http://localhost:8000
