# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001
VITE_RADIO_URL=http://localhost:8001
VITE_DEFAULT_CITY=global

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=radio_db

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_32char_secret

# ── AI (Google Gemini) ────────────────────────────────────────
GEMINI_KEY=AIzaSyB2VrVLqd5p_s30nKs7mB7GJ9fO70_vkpI
GEMINI_MODEL=gemini-2.5-flash

# ── STT (faster-whisper) ─────────────────────────────────────
WHISPER_MODEL=small

# ── TTS ───────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs            # elevenlabs | edge
TTS_FALLBACK_EDGE=true
ELEVENLABS_API_KEY=
ELEVEN_MODEL=eleven_multilingual_v2
ELEVEN_VOICE_RU=
ELEVEN_VOICE_LT=
ELEVEN_VOICE_EN=

# ── Icecast ───────────────────────────────────────────────────
USE_ICECAST=false                  # production: true
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_PASS=IcecastPass2025!

# ── Storage ───────────────────────────────────────────────────
AUDIO_DIR=/tmp/sphera_audio
UPLOAD_DIR=/tmp/sphera_uploads

# ── Points cost-model ─────────────────────────────────────────
COST_CHAT=1
COST_CHAT_VOICE=1
COST_STUDIO=1
COST_STUDIO_VOICE=2
INITIAL_POINTS=50
