# ============================================================
#  Sphera Radio AI v2.0 — Environment Variables
#  Nusxa oling: cp .env.example .env
# ============================================================

# ── App ───────────────────────────────────────────────────────
DEBUG=true                             # production: false (JSON logs, no docs)

# ── Telegram ─────────────────────────────────────────────────
BOT_TOKEN=your_botfather_token_here
ADMIN_IDS=123456789                    # @userinfobot dan oling
COMMUNITY_CHAT_ID=                     # Guruh ID, bo'sh = dev rejim
DISABLE_GROUP_CHECK=true               # production: false

# ── Mini App / API ────────────────────────────────────────────
MINI_APP_URL=http://localhost:5173
API_URL=http://localhost:8001
INTERNAL_API_URL=http://localhost:8001
RADIO_PUBLIC_URL=http://localhost:8000
MINIAPP_DIR=frontend/dist

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001
VITE_RADIO_URL=http://localhost:8001
VITE_DEFAULT_CITY=global

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=radio_db
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_32char_secret_now
INTERNAL_API_KEY=                      # production: random key for service-to-service auth
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8001

# ── AI (Google Gemini) ────────────────────────────────────────
GEMINI_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── STT (faster-whisper) ─────────────────────────────────────
WHISPER_MODEL=small

# ── TTS ───────────────────────────────────────────────────────
TTS_PROVIDER=edge                      # elevenlabs | edge
TTS_FALLBACK_EDGE=true
ELEVENLABS_API_KEY=
ELEVEN_MODEL=eleven_multilingual_v2
ELEVEN_VOICE_RU=
ELEVEN_VOICE_LT=
ELEVEN_VOICE_EN=

# ── Icecast ───────────────────────────────────────────────────
USE_ICECAST=false                      # production: true
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_PASS=change_this_icecast_password

# ── Storage ───────────────────────────────────────────────────
AUDIO_DIR=/tmp/sphera_audio
UPLOAD_DIR=/tmp/sphera_uploads
MAX_UPLOAD_MB=20

# ── Points cost-model ─────────────────────────────────────────
COST_CHAT=1
COST_CHAT_VOICE=1
COST_STUDIO=1
COST_STUDIO_VOICE=2
INITIAL_POINTS=50

# ── Aggregator ────────────────────────────────────────────────
AGGREGATOR_MIN_MESSAGES=5
AGGREGATOR_INTERVAL=120
